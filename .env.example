# Copy to .env.local for local dev. Only variables prefixed with VITE_ are exposed to the browser.
# Never put Stripe secret keys, Shopify admin tokens, or webhooks here.

# Optional: canonical site URL for meta / future OG tags
# VITE_PUBLIC_SITE_URL=https://elsewhereandco.shop

# Optional: Cloudflare Turnstile site key (public). Secret key stays on the server only.
# VITE_TURNSTILE_SITE_KEY=
